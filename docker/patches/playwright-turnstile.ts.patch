+// ── Turnstile solver (optional, disabled by default) ─────────────────────────
+// Set TURNSTILE_SOLVER=capmonster|2captcha and TURNSTILE_SOLVER_API_KEY=<key>
+// in your .env to enable. When unset, this code is a no-op.
+
+const TURNSTILE_SOLVER     = process.env.TURNSTILE_SOLVER || "";
+const TURNSTILE_SOLVER_KEY = process.env.TURNSTILE_SOLVER_API_KEY || "";
+const SOLVER_TIMEOUT_MS    = 60_000;
+
+function httpPost(url: string, body: object): Promise<any> {
+  return new Promise((resolve, reject) => {
+    const data = JSON.stringify(body);
+    const u    = new URL(url);
+    const req  = https.request(
+      { hostname: u.hostname, path: u.pathname + u.search, method: "POST",
+        headers: { "Content-Type": "application/json", "Content-Length": Buffer.byteLength(data) } },
+      (res) => {
+        let buf = "";
+        res.on("data", (c) => (buf += c));
+        res.on("end", () => {
+          try { resolve(JSON.parse(buf)); } catch { resolve(buf); }
+        });
+      }
+    );
+    req.on("error", reject);
+    req.write(data);
+    req.end();
+  });
+}
+
+function httpGet(url: string): Promise<any> {
+  return new Promise((resolve, reject) => {
+    const u = new URL(url);
+    https.get({ hostname: u.hostname, path: u.pathname + u.search }, (res) => {
+      let buf = "";
+      res.on("data", (c) => (buf += c));
+      res.on("end", () => {
+        try { resolve(JSON.parse(buf)); } catch { resolve(buf); }
+      });
+    }).on("error", reject);
+  });
+}
+
+async function solveTurnstileCapMonster(sitekey: string, pageUrl: string): Promise<string | null> {
+  const createResp = await httpPost("https://api.capmonster.cloud/createTask", {
+    clientKey: TURNSTILE_SOLVER_KEY,
+    task: { type: "TurnstileTaskProxyless", websiteURL: pageUrl, websiteKey: sitekey },
+  });
+  const taskId = createResp?.taskId;
+  if (!taskId) return null;
+
+  const deadline = Date.now() + SOLVER_TIMEOUT_MS;
+  while (Date.now() < deadline) {
+    await new Promise((r) => setTimeout(r, 3000));
+    const poll = await httpGet(
+      `https://api.capmonster.cloud/getTaskResult?clientKey=${TURNSTILE_SOLVER_KEY}&taskId=${taskId}`
+    );
+    if (poll?.status === "ready") return poll?.solution?.token ?? null;
+    if (poll?.status === "failed") return null;
+  }
+  return null;
+}
+
+async function solveTurnstile2Captcha(sitekey: string, pageUrl: string): Promise<string | null> {
+  const createResp = await httpPost("https://api.2captcha.com/createTask", {
+    clientKey: TURNSTILE_SOLVER_KEY,
+    task: { type: "TurnstileTaskProxyless", websiteURL: pageUrl, websiteKey: sitekey },
+  });
+  const taskId = createResp?.taskId;
+  if (!taskId) return null;
+
+  const deadline = Date.now() + SOLVER_TIMEOUT_MS;
+  while (Date.now() < deadline) {
+    await new Promise((r) => setTimeout(r, 3000));
+    const poll = await httpGet(
+      `https://api.2captcha.com/getTaskResult?clientKey=${TURNSTILE_SOLVER_KEY}&taskId=${taskId}`
+    );
+    if (poll?.status === "ready") return poll?.solution?.token ?? null;
+    if (poll?.status === "failed") return null;
+  }
+  return null;
+}
+
+async function maybeBypassTurnstile(page: Page): Promise<void> {
+  if (!TURNSTILE_SOLVER || !TURNSTILE_SOLVER_KEY) return;
+  try {
+    const sitekey = await page.$eval('[data-sitekey]', (el) => el.getAttribute('data-sitekey'));
+    if (!sitekey) return;
+    const pageUrl = page.url();
+    let token: string | null = null;
+    if (TURNSTILE_SOLVER === "capmonster") {
+      token = await solveTurnstileCapMonster(sitekey, pageUrl);
+    } else if (TURNSTILE_SOLVER === "2captcha") {
+      token = await solveTurnstile2Captcha(sitekey, pageUrl);
+    }
+    if (!token) return;
+    // Inject token via window.turnstile callback or hidden input
+    await page.evaluate((t) => {
+      if (typeof (window as any).turnstile?.callback === "function") {
+        (window as any).turnstile.callback(t);
+      } else {
+        const inp = document.querySelector<HTMLInputElement>('[name="cf-turnstile-response"]');
+        if (inp) { inp.value = t; inp.dispatchEvent(new Event("change")); }
+      }
+    }, token);
+  } catch {
+    // Best-effort; non-Turnstile pages will throw on $eval — ignore
+  }
+}
+
+// ── End Turnstile solver ──────────────────────────────────────────────────────
+
