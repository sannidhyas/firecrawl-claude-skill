# Firecrawl self-hosted — default environment
# Copy to $FIRECRAWL_INSTALL_DIR/.env and adjust as needed.
# install.sh writes this automatically if .env is absent.

PORT=3002
INTERNAL_PORT=3002
HOST=0.0.0.0
USE_DB_AUTHENTICATION=false

# --- concurrency ---
NUM_WORKERS_PER_QUEUE=8
CRAWL_CONCURRENT_REQUESTS=16
MAX_CONCURRENT_JOBS=6
BROWSER_POOL_SIZE=6

BULL_AUTH_KEY=localdev
LOGGING_LEVEL=INFO
ALLOW_LOCAL_WEBHOOKS=true

# --- local LLM (ollama) ---
# llama3.2:3b is ~2 GB and fast to pull; swap to qwen2.5:7b for better extraction quality.
MODEL_NAME=llama3.2:3b
MODEL_EMBEDDING_NAME=nomic-embed-text

# --- antibot tuning ---
# Retries and wait before each antibot retry (milliseconds).
# Increase SELF_HOST_ANTIBOT_WAIT_MS to give Cloudflare JS-challenge pages more time.
SELF_HOST_ANTIBOT_RETRIES=3
SELF_HOST_ANTIBOT_WAIT_MS=2000

# --- proxy (optional) ---
# For IP rotation on Cloudflare-protected pages, supply your own proxy.
# Integrated Tor was dropped — unreliable bootstrap + most exits pre-blocked by CF.
# Example: PROXY_SERVER=socks5://your-proxy:1080
PROXY_SERVER=
PROXY_USERNAME=
PROXY_PASSWORD=
