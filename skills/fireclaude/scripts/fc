#!/usr/bin/env bash
# firecrawl wrapper - talks to local self-hosted Firecrawl
set -euo pipefail

FC_URL="${FIRECRAWL_URL:-http://localhost:3002}"

# ── Ollama endpoint resolution ────────────────────────────────────────────────
# Inside container → host.docker.internal:11434; on host → localhost:11434.
# Reads OLLAMA_BASE_URL from .env if available, else falls back to localhost.
_resolve_ollama_url() {
  local fc_repo=""
  fc_repo="$(_resolve_install_dir 2>/dev/null)" || true
  local env_file="${fc_repo}/.env"
  local base_url=""
  if [[ -f "$env_file" ]]; then
    base_url=$(grep '^OLLAMA_BASE_URL=' "$env_file" 2>/dev/null | cut -d= -f2- | tr -d '"' || true)
  fi
  # If OLLAMA_BASE_URL env is set directly, prefer it
  [[ -n "${OLLAMA_BASE_URL:-}" ]] && base_url="${OLLAMA_BASE_URL}"
  # Normalise to host-facing URL (strip /api suffix if any, then re-add)
  base_url="${base_url:-http://localhost:11434/api}"
  # When running from the host CLI, translate host.docker.internal → localhost
  base_url="${base_url//host.docker.internal/localhost}"
  echo "$base_url"
}

_resolve_ollama_mode() {
  local fc_repo=""
  fc_repo="$(_resolve_install_dir 2>/dev/null)" || true
  local env_file="${fc_repo}/.env"
  local mode="auto"
  if [[ -f "$env_file" ]]; then
    mode=$(grep '^OLLAMA_MODE=' "$env_file" 2>/dev/null | cut -d= -f2- | tr -d '"' || echo "auto")
  fi
  [[ -n "${OLLAMA_MODE:-}" ]] && mode="${OLLAMA_MODE}"
  echo "${mode:-auto}"
}

_ollama_host_reachable() {
  curl -sf --max-time 3 http://localhost:11434/api/tags >/dev/null 2>&1
}

# ── Install dir resolution ────────────────────────────────────────────────────
# 1. FIRECRAWL_INSTALL_DIR (legacy, keeps backward compat)
# 2. FIRECLAUDE_INSTALL_DIR (new alias)
# 3. $HOME/.fireclaude/firecrawl (standard install dir)
_resolve_install_dir() {
  if [[ -n "${FIRECRAWL_INSTALL_DIR:-}" ]]; then
    echo "$FIRECRAWL_INSTALL_DIR"
  elif [[ -n "${FIRECLAUDE_INSTALL_DIR:-}" ]]; then
    echo "$FIRECLAUDE_INSTALL_DIR"
  elif [[ -d "$HOME/.fireclaude/firecrawl" ]]; then
    echo "$HOME/.fireclaude/firecrawl"
  else
    die "install dir not found. Run 'fireclaude setup' first, or set FIRECRAWL_INSTALL_DIR."
  fi
}

FC_SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CHANGES_DB_PATH="${CHANGES_DB_PATH:-$HOME/.fireclaude/changes.db}"

# Container name derives from COMPOSE_PROJECT_NAME (default: firecrawl)
_COMPOSE_PROJECT="${COMPOSE_PROJECT_NAME:-firecrawl}"
OLLAMA_CONTAINER="${_COMPOSE_PROJECT}-ollama-1"

# ── Plugin version (read from package.json next to repo root) ─────────────────
_plugin_version() {
  local pkg
  # Walk up from script dir looking for package.json with a "version" field
  local d="$FC_SCRIPT_DIR"
  for _ in 1 2 3 4 5; do
    d="$(dirname "$d")"
    pkg="$d/package.json"
    if [[ -f "$pkg" ]]; then
      local v
      v=$(node -e "try{process.stdout.write(require('$pkg').version||'')}catch(e){}" 2>/dev/null || true)
      [[ -n "$v" ]] && echo "$v" && return
    fi
  done
  # fallback: try npm root -g
  local npm_pkg
  npm_pkg="$(npm root -g 2>/dev/null)/fireclaude/package.json" || true
  if [[ -f "$npm_pkg" ]]; then
    node -e "try{process.stdout.write(require('$npm_pkg').version||'')}catch(e){}" 2>/dev/null || true
    return
  fi
  echo "unknown"
}

# ── install.sh resolution ─────────────────────────────────────────────────────
_resolve_install_sh() {
  # 1. Explicit env var
  if [[ -n "${FIRECLAUDE_INSTALL_SH:-}" && -f "$FIRECLAUDE_INSTALL_SH" ]]; then
    echo "$FIRECLAUDE_INSTALL_SH"; return
  fi
  # 2. npm global root
  local npm_root
  npm_root="$(npm root -g 2>/dev/null)" || true
  if [[ -n "$npm_root" && -f "$npm_root/fireclaude/install.sh" ]]; then
    echo "$npm_root/fireclaude/install.sh"; return
  fi
  # 3. Repo root (git checkout)
  local repo_root
  repo_root="$(git -C "$FC_SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null)" || true
  if [[ -n "$repo_root" && -f "$repo_root/install.sh" ]]; then
    echo "$repo_root/install.sh"; return
  fi
  # 4. Walk up from script dir
  local d="$FC_SCRIPT_DIR"
  for _ in 1 2 3 4 5; do
    d="$(dirname "$d")"
    if [[ -f "$d/install.sh" ]]; then
      echo "$d/install.sh"; return
    fi
  done
  # 5. Download fallback
  local ver
  ver="$(_plugin_version)"
  echo "https://raw.githubusercontent.com/sannidhyas/fireclaude/v${ver}/install.sh"
}

_resolve_uninstall_sh() {
  if [[ -n "${FIRECLAUDE_INSTALL_SH:-}" ]]; then
    local base
    base="$(dirname "$FIRECLAUDE_INSTALL_SH")"
    [[ -f "$base/uninstall.sh" ]] && echo "$base/uninstall.sh" && return
  fi
  local npm_root
  npm_root="$(npm root -g 2>/dev/null)" || true
  if [[ -n "$npm_root" && -f "$npm_root/fireclaude/uninstall.sh" ]]; then
    echo "$npm_root/fireclaude/uninstall.sh"; return
  fi
  local repo_root
  repo_root="$(git -C "$FC_SCRIPT_DIR" rev-parse --show-toplevel 2>/dev/null)" || true
  if [[ -n "$repo_root" && -f "$repo_root/uninstall.sh" ]]; then
    echo "$repo_root/uninstall.sh"; return
  fi
  local d="$FC_SCRIPT_DIR"
  for _ in 1 2 3 4 5; do
    d="$(dirname "$d")"
    if [[ -f "$d/uninstall.sh" ]]; then
      echo "$d/uninstall.sh"; return
    fi
  done
  local ver
  ver="$(_plugin_version)"
  echo "https://raw.githubusercontent.com/sannidhyas/fireclaude/v${ver}/uninstall.sh"
}

die() { echo "fc: $*" >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || die "missing dep: $1"; }
need curl
need jq

usage() {
  cat <<EOF
fireclaude - Firecrawl self-host wrapper  (fireclaude v$(_plugin_version 2>/dev/null || echo '?'))

Lifecycle:
  fireclaude setup [--install-dir PATH] [--model NAME]   bootstrap stack (runs install.sh)
  fireclaude start                                        start stopped containers
  fireclaude stop                                         stop running containers
  fireclaude status [--json]                              container status
  fireclaude teardown [--purge]                           stop + remove stack (--purge skips prompts)
  fireclaude upgrade [--sha GIT_SHA]                      pull latest fireclaude, rebuild, restart
  fireclaude version                                      fireclaude version + firecrawl SHA + models
  fireclaude doctor [--json]                              dep check + container health + model presence + ollama info
  fireclaude ollama-start                                 start host ollama via systemd-user (Linux) or brew/launchctl (macOS)
  fireclaude alias install [--yes]                        write alias fc='fireclaude' to ~/.bashrc / ~/.zshrc
  fireclaude alias uninstall [--yes]                      remove the alias from shell rc files

Data commands:
  fireclaude scrape <url> [--format markdown|html|links|screenshot] [--raw] [--json]
  fireclaude batch <urls.txt> [--out dataset.jsonl] [--format markdown] [--json]
  fireclaude search "<query>" [--limit N] [--json]
  fireclaude map <url> [--json]
  fireclaude crawl <url> [--limit N] [--out dir] [--json]
  fireclaude extract <url> --schema <file.json> [--prompt STR] [--json]
  fireclaude model list
  fireclaude model pull <name>
  fireclaude model swap <name>
  fireclaude model current
  fireclaude changes <url> [--diff] [--json]
  fireclaude webhook-listen [--port N] [--json]
  fireclaude health
  fireclaude logs [api|playwright-service|redis|rabbitmq|searxng|ollama]

Agent-safe JSON endpoints: fireclaude doctor --json  |  fireclaude status --json  |  fireclaude scrape --json

ENV: FIRECRAWL_URL (default $FC_URL)
     FIRECRAWL_INSTALL_DIR / FIRECLAUDE_INSTALL_DIR (install dir, default ~/.fireclaude/firecrawl)
     OLLAMA_MODE (auto|host|container, default auto)
     CHANGES_DB_PATH (default \$HOME/.fireclaude/changes.db)
     FIRECLAUDE_INSTALL_SH (override install.sh path)
EOF
}

post() {
  local path="$1" body="$2"
  curl -sS -X POST "$FC_URL$path" -H 'Content-Type: application/json' -d "$body"
}
get() { curl -sS "$FC_URL$1"; }

# ── Lifecycle commands ────────────────────────────────────────────────────────

cmd_setup() {
  local install_dir="" model_name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --install-dir) install_dir="$2"; shift 2 ;;
      --model)       model_name="$2"; shift 2 ;;
      *) die "setup: unknown arg: $1" ;;
    esac
  done

  local install_sh
  install_sh="$(_resolve_install_sh)"

  local env_extra=()
  [[ -n "$install_dir" ]] && env_extra+=("FIRECRAWL_INSTALL_DIR=$install_dir")
  [[ -n "$model_name" ]]  && env_extra+=("MODEL_NAME=$model_name")

  if [[ "$install_sh" == http* ]]; then
    echo "fc: downloading install.sh from $install_sh ..." >&2
    local tmp_sh
    tmp_sh="$(mktemp /tmp/fireclaude-install-XXXXXX.sh)"
    curl -sSL "$install_sh" -o "$tmp_sh" || die "could not download install.sh from $install_sh"
    chmod +x "$tmp_sh"
    env "${env_extra[@]}" bash "$tmp_sh"
    rm -f "$tmp_sh"
  else
    chmod +x "$install_sh"
    env "${env_extra[@]}" bash "$install_sh"
  fi
}

cmd_start() {
  local fc_repo
  fc_repo="$(_resolve_install_dir)"
  local mode
  mode="$(_resolve_ollama_mode)"
  if [[ "$mode" == "container" ]]; then
    (cd "$fc_repo" && \
      COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
      docker compose --project-name "${_COMPOSE_PROJECT}" --profile container-ollama up -d)
  else
    (cd "$fc_repo" && \
      COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
      docker compose --project-name "${_COMPOSE_PROJECT}" up -d)
  fi
}

cmd_stop() {
  local fc_repo
  fc_repo="$(_resolve_install_dir)"
  (cd "$fc_repo" && \
    COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
    docker compose --project-name "${_COMPOSE_PROJECT}" stop)
}

cmd_status() {
  local json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_out=1; shift ;;
      *) die "status: unknown arg: $1" ;;
    esac
  done
  local fc_repo
  fc_repo="$(_resolve_install_dir)"

  if [[ "$json_out" -eq 1 ]]; then
    # Emit array of {service, state} objects
    local raw
    raw=$(cd "$fc_repo" && \
      COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
      docker compose --project-name "${_COMPOSE_PROJECT}" ps --format json 2>/dev/null) || raw="[]"
    # docker compose ps --format json outputs one JSON object per line (not an array)
    echo "$raw" | jq -s '[.[] | {service: (.Service // .Name // "unknown"), state: (.State // .Status // "unknown")}]'
  else
    (cd "$fc_repo" && \
      COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
      docker compose --project-name "${_COMPOSE_PROJECT}" ps)
  fi
}

cmd_teardown() {
  local purge=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --purge) purge=1; shift ;;
      *) die "teardown: unknown arg: $1" ;;
    esac
  done

  local uninstall_sh
  uninstall_sh="$(_resolve_uninstall_sh)"

  if [[ "$uninstall_sh" == http* ]]; then
    echo "fc: downloading uninstall.sh from $uninstall_sh ..." >&2
    local tmp_sh
    tmp_sh="$(mktemp /tmp/fireclaude-uninstall-XXXXXX.sh)"
    curl -sSL "$uninstall_sh" -o "$tmp_sh" || die "could not download uninstall.sh"
    chmod +x "$tmp_sh"
    if [[ "$purge" -eq 1 ]]; then
      # Auto-answer yes to both prompts via stdin
      printf 'y\ny\n' | bash "$tmp_sh"
    else
      bash "$tmp_sh"
    fi
    rm -f "$tmp_sh"
  else
    chmod +x "$uninstall_sh"
    if [[ "$purge" -eq 1 ]]; then
      printf 'y\ny\n' | bash "$uninstall_sh"
    else
      bash "$uninstall_sh"
    fi
  fi
}

cmd_upgrade() {
  local sha=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --sha) sha="$2"; shift 2 ;;
      *) die "upgrade: unknown arg: $1" ;;
    esac
  done

  local fc_repo
  fc_repo="$(_resolve_install_dir)"

  # 1. Try to upgrade the npm package itself (only if installed via npm globally)
  local npm_root
  npm_root="$(npm root -g 2>/dev/null)" || true
  if [[ -n "$npm_root" && -d "$npm_root/fireclaude" ]]; then
    echo "fc: upgrading fireclaude npm package..." >&2
    npm install -g fireclaude 2>&1 || echo "fc: npm upgrade failed, continuing with existing version" >&2
  fi

  # 2. If --sha given, checkout new firecrawl SHA, re-apply patches, rebuild
  if [[ -n "$sha" ]]; then
    echo "fc: pinning firecrawl to SHA $sha ..." >&2
    git -C "$fc_repo" fetch --quiet origin
    git -C "$fc_repo" checkout --quiet "$sha" || die "could not checkout SHA $sha"

    # Re-apply patches from install.sh location
    local install_sh
    install_sh="$(_resolve_install_sh)"
    if [[ "$install_sh" != http* ]]; then
      local plugin_root
      plugin_root="$(dirname "$install_sh")"
      echo "fc: re-applying patches from $plugin_root/docker/patches/ ..." >&2
      for patch in "$plugin_root/docker/patches/"*.patch; do
        [[ -f "$patch" ]] || continue
        pname="$(basename "$patch")"
        if git -C "$fc_repo" apply --check "$patch" >/dev/null 2>&1; then
          git -C "$fc_repo" apply --3way "$patch" 2>&1 || echo "fc: patch $pname failed (skipping)" >&2
        elif git -C "$fc_repo" apply --check --reverse "$patch" >/dev/null 2>&1; then
          echo "fc: $pname already applied" >&2
        else
          echo "fc: $pname cannot be applied (skipping)" >&2
        fi
      done
    fi

    # Rebuild api + playwright-service
    echo "fc: rebuilding api + playwright-service ..." >&2
    (cd "$fc_repo" && \
      COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
      docker compose --project-name "${_COMPOSE_PROJECT}" build api playwright-service)
  fi

  # 3. Restart stack
  echo "fc: restarting stack ..." >&2
  (cd "$fc_repo" && \
    COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
    docker compose --project-name "${_COMPOSE_PROJECT}" up -d)

  echo "fc: upgrade complete." >&2
}

cmd_version() {
  local ver
  ver="$(_plugin_version)"
  echo "fireclaude: $ver"

  local fc_repo=""
  fc_repo="$(_resolve_install_dir 2>/dev/null)" || true
  if [[ -n "$fc_repo" && -d "$fc_repo/.git" ]]; then
    local sha
    sha=$(git -C "$fc_repo" rev-parse HEAD 2>/dev/null || echo "unknown")
    echo "firecrawl SHA: $sha"
  else
    echo "firecrawl SHA: (stack not installed)"
  fi

  local mode
  mode="$(_resolve_ollama_mode)"
  local ollama_url
  ollama_url="$(_resolve_ollama_url)"
  echo "ollama mode:   $mode"
  echo "ollama url:    $ollama_url"

  echo "ollama models:"
  if [[ "$mode" == "container" ]]; then
    docker exec "$OLLAMA_CONTAINER" ollama list 2>/dev/null | tail -n +2 | awk '{print "  " $1}' || \
      echo "  (ollama container not running)"
  else
    curl -sf --max-time 5 "${ollama_url%/api}/api/tags" 2>/dev/null \
      | jq -r '.models[]?.name // empty' 2>/dev/null | awk '{print "  " $1}' || \
      echo "  (host ollama not reachable at $ollama_url)"
  fi
}

cmd_doctor() {
  local json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_out=1; shift ;;
      *) die "doctor: unknown arg: $1" ;;
    esac
  done

  # ── dep checks ───────────────────────────────────────────────────────────────
  local deps_json="{"
  local first=1
  for dep in docker git curl jq python3 node; do
    local ok
    command -v "$dep" >/dev/null 2>&1 && ok="true" || ok="false"
    [[ "$first" -eq 0 ]] && deps_json+=","
    deps_json+="\"$dep\":$ok"
    first=0
  done
  # docker compose plugin
  local compose_ok
  docker compose version >/dev/null 2>&1 && compose_ok="true" || compose_ok="false"
  deps_json+=",\"docker-compose\":$compose_ok"
  deps_json+="}"

  # ── container health ─────────────────────────────────────────────────────────
  local containers_json="[]"
  local fc_repo=""
  fc_repo="$(_resolve_install_dir 2>/dev/null)" || true
  if [[ -n "$fc_repo" ]]; then
    local raw
    raw=$(cd "$fc_repo" && \
      COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
      docker compose --project-name "${_COMPOSE_PROJECT}" ps --format json 2>/dev/null) || raw=""
    if [[ -n "$raw" ]]; then
      containers_json=$(echo "$raw" | jq -s '[.[] | {service: (.Service // .Name // "unknown"), state: (.State // .Status // "unknown")}]')
    fi
  fi

  # ── model presence ───────────────────────────────────────────────────────────
  local models_json="[]"
  local ollama_mode ollama_endpoint ollama_reachable ollama_gpu_detected ollama_gpu_name
  ollama_mode="$(_resolve_ollama_mode)"
  ollama_endpoint="$(_resolve_ollama_url)"
  # Normalise endpoint to root for tags check
  local tags_url="${ollama_endpoint%/api}/api/tags"
  if [[ "$ollama_mode" == "container" ]]; then
    models_json=$(docker exec "$OLLAMA_CONTAINER" ollama list 2>/dev/null \
      | tail -n +2 | awk '{print $1}' | jq -Rn '[inputs]') || models_json="[]"
    if docker exec "$OLLAMA_CONTAINER" ollama list >/dev/null 2>&1; then
      ollama_reachable="true"
    else
      ollama_reachable="false"
    fi
  else
    # Host mode — probe via HTTP
    local tags_resp
    tags_resp=$(curl -sf --max-time 5 "$tags_url" 2>/dev/null || echo "")
    if [[ -n "$tags_resp" ]]; then
      ollama_reachable="true"
      models_json=$(echo "$tags_resp" | jq '[.models[]?.name // empty]' 2>/dev/null || echo "[]")
    else
      ollama_reachable="false"
      models_json="[]"
    fi
  fi

  # GPU detection (best-effort)
  ollama_gpu_detected="false"
  ollama_gpu_name=""
  if command -v nvidia-smi >/dev/null 2>&1; then
    local gpu_name
    gpu_name=$(nvidia-smi --query-gpu=name --format=csv,noheader 2>/dev/null | head -1 || true)
    if [[ -n "$gpu_name" ]]; then
      ollama_gpu_detected="true"
      ollama_gpu_name="$gpu_name"
    fi
  elif [[ -d /dev/dri ]]; then
    ollama_gpu_detected="true"
    ollama_gpu_name="unknown (DRI device found)"
  fi

  local ollama_json
  ollama_json=$(jq -n \
    --arg mode "$ollama_mode" \
    --arg endpoint "$ollama_endpoint" \
    --argjson reachable "$ollama_reachable" \
    --argjson models "$models_json" \
    --argjson gpu_detected "$ollama_gpu_detected" \
    --arg gpu_name "$ollama_gpu_name" \
    '{mode: $mode, endpoint: $endpoint, reachable: $reachable, models: $models, gpu: {detected: $gpu_detected, name: $gpu_name}}')

  if [[ "$json_out" -eq 1 ]]; then
    jq -n \
      --argjson deps "$deps_json" \
      --argjson containers "$containers_json" \
      --argjson models "$models_json" \
      --argjson ollama "$ollama_json" \
      '{deps: $deps, containers: $containers, models: $models, ollama: $ollama}'
  else
    echo "=== Dependencies ==="
    echo "$deps_json" | jq -r 'to_entries[] | "\(.key): \(.value)"'
    echo ""
    echo "=== Containers ==="
    echo "$containers_json" | jq -r '.[] | "\(.service): \(.state)"'
    echo ""
    echo "=== Ollama ==="
    echo "  mode:      $ollama_mode"
    echo "  endpoint:  $ollama_endpoint"
    echo "  reachable: $ollama_reachable"
    echo "  gpu:       $ollama_gpu_detected ($ollama_gpu_name)"
    echo "  models:"
    echo "$models_json" | jq -r '.[]' | awk '{print "    " $1}'
  fi
}

cmd_ollama_start() {
  local uname_s
  uname_s="$(uname -s)"
  if [[ "$uname_s" == "Linux" ]]; then
    # Try systemd --user first
    if systemctl --user is-enabled ollama >/dev/null 2>&1 || systemctl --user status ollama >/dev/null 2>&1; then
      echo "Starting ollama via systemd --user ..." >&2
      systemctl --user start ollama || die "systemctl --user start ollama failed"
    else
      echo "systemd unit 'ollama' not found — starting via nohup ..." >&2
      nohup ollama serve >/tmp/ollama-serve.log 2>&1 &
      echo "ollama serve launched (PID $!, log: /tmp/ollama-serve.log)" >&2
    fi
  elif [[ "$uname_s" == "Darwin" ]]; then
    # Try brew services first, then launchctl
    if command -v brew >/dev/null 2>&1 && brew list ollama >/dev/null 2>&1; then
      echo "Starting ollama via brew services ..." >&2
      brew services start ollama || die "brew services start ollama failed"
    elif [[ -f "$HOME/Library/LaunchAgents/com.ollama.ollama.plist" ]]; then
      echo "Starting ollama via launchctl ..." >&2
      launchctl load "$HOME/Library/LaunchAgents/com.ollama.ollama.plist" || \
        die "launchctl load failed"
    else
      echo "No brew or launchctl plist found — starting via nohup ..." >&2
      nohup ollama serve >/tmp/ollama-serve.log 2>&1 &
      echo "ollama serve launched (PID $!, log: /tmp/ollama-serve.log)" >&2
    fi
  else
    die "ollama-start: unsupported OS '$uname_s'. Start ollama manually: ollama serve"
  fi

  # Wait up to 15s for daemon to become reachable
  local deadline=$((SECONDS + 15))
  echo -n "Waiting for ollama at http://localhost:11434 " >&2
  while [[ $SECONDS -lt $deadline ]]; do
    if curl -sf --max-time 2 http://localhost:11434/api/tags >/dev/null 2>&1; then
      echo " ready." >&2
      local version
      version=$(curl -sf --max-time 3 http://localhost:11434/api/version 2>/dev/null | jq -r '.version // "unknown"' || echo "unknown")
      echo "ollama endpoint: http://localhost:11434  version: $version"
      return 0
    fi
    echo -n "." >&2
    sleep 1
  done
  echo "" >&2
  die "ollama did not become reachable within 15s. Check logs."
}

# ── Stack commands ────────────────────────────────────────────────────────────

cmd_health() {
  local r
  r=$(curl -sS -o /dev/null -w '%{http_code}' "$FC_URL/v2/scrape" -X POST \
      -H 'Content-Type: application/json' -d '{"url":"https://example.com","formats":["markdown"]}' || true)
  if [[ "$r" =~ ^(200|408|500)$ ]]; then
    echo "firecrawl reachable at $FC_URL (HTTP $r)"
  else
    die "firecrawl unreachable at $FC_URL (HTTP $r)"
  fi
}

cmd_logs() {
  local svc="${1:-api}"
  local fc_repo
  fc_repo="$(_resolve_install_dir)"
  (cd "$fc_repo" && \
    COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
    docker compose --project-name "${_COMPOSE_PROJECT}" logs --tail=200 "$svc")
}

# ── Data commands ─────────────────────────────────────────────────────────────

cmd_scrape() {
  [[ $# -ge 1 ]] || die "scrape needs <url>"
  local url="$1"; shift
  local fmt="markdown" raw=0 json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --format) fmt="$2"; shift 2 ;;
      --raw) raw=1; shift ;;
      --json) json_out=1; shift ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  local body
  body=$(jq -nc --arg u "$url" --arg f "$fmt" '{url:$u, formats:[$f], onlyMainContent:true}')
  local resp; resp=$(post /v2/scrape "$body")
  if [[ "$json_out" -eq 1 ]]; then echo "$resp"; return; fi
  if [[ "$raw" -eq 1 ]]; then echo "$resp"; return; fi
  echo "$resp" | jq -r ".data.$fmt // .data // .error // \"(no $fmt)\""
}

cmd_map() {
  [[ $# -ge 1 ]] || die "map needs <url>"
  local url="$1"; shift
  local json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --json) json_out=1; shift ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  local body; body=$(jq -nc --arg u "$url" '{url:$u}')
  local resp; resp=$(post /v2/map "$body")
  if [[ "$json_out" -eq 1 ]]; then echo "$resp"; return; fi
  echo "$resp" | jq -r '.links[]? // .data.links[]? // empty'
}

cmd_search() {
  [[ $# -ge 1 ]] || die "search needs <query>"
  local q="$1"; shift
  local limit=10 json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit) limit="$2"; shift 2 ;;
      --json) json_out=1; shift ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  local body; body=$(jq -nc --arg q "$q" --argjson n "$limit" '{query:$q, limit:$n}')
  local resp; resp=$(post /v2/search "$body")
  if [[ "$json_out" -eq 1 ]]; then echo "$resp"; return; fi
  echo "$resp" | jq '.data // .'
}

cmd_batch() {
  [[ $# -ge 1 ]] || die "batch needs <urls.txt>"
  local urls_file="$1"; shift
  local out="" fmt="markdown" json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --out) out="$2"; shift 2 ;;
      --format) fmt="$2"; shift 2 ;;
      --json) json_out=1; shift ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  [[ -f "$urls_file" ]] || die "no such file: $urls_file"
  local extra_args=()
  [[ "$json_out" -eq 1 ]] && extra_args+=("--json")
  exec python3 "$FC_SCRIPT_DIR/batch-dataset.py" \
      --urls "$urls_file" \
      ${out:+--out "$out"} \
      --format "$fmt" \
      --only-main \
      "${extra_args[@]}"
}

cmd_crawl() {
  [[ $# -ge 1 ]] || die "crawl needs <url>"
  local url="$1"; shift
  local limit=20 out="" json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --limit) limit="$2"; shift 2 ;;
      --out) out="$2"; shift 2 ;;
      --json) json_out=1; shift ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  local body; body=$(jq -nc --arg u "$url" --argjson n "$limit" \
    '{url:$u, limit:$n, scrapeOptions:{formats:["markdown"], onlyMainContent:true}}')
  local start; start=$(post /v2/crawl "$body")
  local id; id=$(echo "$start" | jq -r '.id // .jobId // empty')
  [[ -n "$id" ]] || { echo "$start" >&2; die "no job id returned"; }
  echo "crawl job id: $id" >&2
  local status resp
  while :; do
    resp=$(get "/v2/crawl/$id")
    status=$(echo "$resp" | jq -r '.status // empty')
    echo "  status=$status completed=$(echo "$resp" | jq -r '.completed // 0')/$(echo "$resp" | jq -r '.total // "?"')" >&2
    [[ "$status" == "completed" || "$status" == "failed" ]] && break
    sleep 3
  done
  if [[ "$json_out" -eq 1 ]]; then echo "$resp"; return; fi
  if [[ -n "$out" ]]; then
    mkdir -p "$out"
    echo "$resp" | jq -c '.data[]?' | while IFS= read -r row; do
      local u safe
      u=$(echo "$row" | jq -r '.metadata.url // .url // "unknown"')
      safe=$(echo "$u" | sed 's|[^a-zA-Z0-9]|_|g' | cut -c1-120)
      echo "$row" | jq -r '.markdown // ""' > "$out/$safe.md"
    done
    echo "wrote $(ls "$out" | wc -l) files to $out" >&2
  else
    echo "$resp" | jq
  fi
}

cmd_extract() {
  [[ $# -ge 1 ]] || die "extract needs <url>"
  local url="$1"; shift
  local schema_file="" prompt="" json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --schema) schema_file="$2"; shift 2 ;;
      --prompt) prompt="$2"; shift 2 ;;
      --json) json_out=1; shift ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  [[ -n "$schema_file" ]] || die "extract needs --schema <file.json>"
  [[ -f "$schema_file" ]] || die "schema file not found: $schema_file"
  local schema; schema=$(cat "$schema_file")
  local fmt_obj
  if [[ -n "$prompt" ]]; then
    fmt_obj=$(jq -nc --argjson s "$schema" --arg p "$prompt" '{type:"json",schema:$s,prompt:$p}')
  else
    fmt_obj=$(jq -nc --argjson s "$schema" '{type:"json",schema:$s}')
  fi
  local body; body=$(jq -nc --arg u "$url" --argjson f "$fmt_obj" '{url:$u,formats:[$f],onlyMainContent:true}')
  local resp; resp=$(post /v2/scrape "$body")
  if [[ "$json_out" -eq 1 ]]; then echo "$resp"; return; fi
  echo "$resp" | jq '.data.json // .data // .error // "(no json)"'
}

cmd_model() {
  local sub="${1:-}"; [[ -n "$sub" ]] || die "model needs: list|pull|swap|current"
  shift
  local mode
  mode="$(_resolve_ollama_mode)"
  local ollama_url
  ollama_url="$(_resolve_ollama_url)"
  # Base URL without /api suffix for raw API calls
  local ollama_base="${ollama_url%/api}"

  case "$sub" in
    list)
      if [[ "$mode" == "container" ]]; then
        docker exec "$OLLAMA_CONTAINER" ollama list | tail -n +2 | awk '{print $1}' | jq -Rn '[inputs]'
      else
        curl -sf --max-time 10 "$ollama_base/api/tags" 2>/dev/null \
          | jq '[.models[]?.name // empty]' 2>/dev/null || echo "[]"
      fi
      ;;
    pull)
      [[ $# -ge 1 ]] || die "model pull needs <name>"
      local model_name="$1"
      if [[ "$mode" == "container" ]]; then
        docker exec "$OLLAMA_CONTAINER" ollama pull "$model_name"
      else
        echo "Pulling $model_name via host ollama at $ollama_base ..." >&2
        curl -sS -X POST "$ollama_base/api/pull" \
          -H 'Content-Type: application/json' \
          -d "{\"name\":\"$model_name\"}" | tail -1
      fi
      ;;
    swap)
      [[ $# -ge 1 ]] || die "model swap needs <name>"
      local name="$1"
      local fc_repo; fc_repo="$(_resolve_install_dir)"
      local env_file="$fc_repo/.env"
      [[ -f "$env_file" ]] || die "no .env at $env_file"
      echo "Pulling $name ..." >&2
      if [[ "$mode" == "container" ]]; then
        docker exec "$OLLAMA_CONTAINER" ollama pull "$name"
      else
        curl -sS -X POST "$ollama_base/api/pull" \
          -H 'Content-Type: application/json' \
          -d "{\"name\":\"$name\"}" | tail -1
      fi
      sed -i "s/^MODEL_NAME=.*/MODEL_NAME=$name/" "$env_file"
      echo "Updated MODEL_NAME=$name in $env_file" >&2
      (cd "$fc_repo" && \
        COMPOSE_PROJECT_NAME="${_COMPOSE_PROJECT}" \
        docker compose --project-name "${_COMPOSE_PROJECT}" up -d --force-recreate api)
      local url="http://localhost:${PORT:-3002}"
      echo "Waiting for API health after swap..." >&2
      local deadline=$((SECONDS + 60))
      while [[ $SECONDS -lt $deadline ]]; do
        local http_code
        http_code=$(curl -sS -o /dev/null -w '%{http_code}' -X POST "$url/v2/scrape" \
          -H 'Content-Type: application/json' \
          -d '{"url":"https://example.com","formats":["markdown"]}' 2>/dev/null || echo "000")
        if [[ "$http_code" =~ ^(200|408|500)$ ]]; then
          echo "API healthy (HTTP $http_code). Model swapped to $name." >&2
          break
        fi
        sleep 3
      done
      echo "$name"
      ;;
    current)
      local fc_repo; fc_repo="$(_resolve_install_dir 2>/dev/null)" || true
      local env_file="${fc_repo:-}/.env"
      if [[ -f "$env_file" ]]; then
        grep '^MODEL_NAME=' "$env_file" | cut -d= -f2-
      else
        echo "${MODEL_NAME:-llama3.2:3b}"
      fi
      ;;
    *) die "model: unknown subcommand '$sub' (list|pull|swap|current)" ;;
  esac
}

cmd_changes() {
  [[ $# -ge 1 ]] || die "changes needs <url>"
  local url="$1"; shift
  local diff_mode=0 json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --diff) diff_mode=1; shift ;;
      --json) json_out=1; shift ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  need python3
  local extra_args=()
  [[ "$diff_mode" -eq 1 ]] && extra_args+=("--diff")
  [[ "$json_out" -eq 1 ]] && extra_args+=("--json")
  python3 "$FC_SCRIPT_DIR/fc-changes.py" \
    --url "$url" \
    --db "$CHANGES_DB_PATH" \
    --firecrawl-url "$FC_URL" \
    "${extra_args[@]}"
}

cmd_webhook_listen() {
  local port=4321 json_out=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --port) port="$2"; shift 2 ;;
      --json) json_out=1; shift ;;
      *) die "unknown arg: $1" ;;
    esac
  done
  need python3
  local extra_args=()
  [[ "$json_out" -eq 1 ]] && extra_args+=("--json")
  exec python3 -u "$FC_SCRIPT_DIR/fc-webhook-listen.py" --port "$port" "${extra_args[@]}"
}

cmd_alias() {
  local sub="${1:-}"; [[ -n "$sub" ]] || die "alias needs: install|uninstall"
  shift
  local yes=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --yes|-y) yes=1; shift ;;
      *) die "alias $sub: unknown arg: $1" ;;
    esac
  done

  local alias_line="alias fc='fireclaude'"
  local rc_files=()
  [[ -f "$HOME/.bashrc" ]]  && rc_files+=("$HOME/.bashrc")
  [[ -f "$HOME/.zshrc" ]]   && rc_files+=("$HOME/.zshrc")

  case "$sub" in
    install)
      if [[ "${#rc_files[@]}" -eq 0 ]]; then
        echo "fireclaude: no ~/.bashrc or ~/.zshrc found — nothing to update." >&2
        exit 0
      fi
      for rc in "${rc_files[@]}"; do
        if grep -qF "$alias_line" "$rc" 2>/dev/null; then
          echo "fireclaude: alias already present in $rc — skipping."
          continue
        fi
        if [[ "$yes" -eq 0 ]]; then
          read -r -p "Add '$alias_line' to $rc? [y/N] " _ans
          _ans="${_ans:-N}"
          [[ "$_ans" =~ ^[Yy]$ ]] || { echo "Skipped $rc."; continue; }
        fi
        printf '\n# fireclaude short alias (added by fireclaude alias install)\n%s\n' "$alias_line" >> "$rc"
        echo "fireclaude: added alias to $rc"
      done
      echo "fireclaude: run 'source ~/.bashrc' (or open a new shell) to activate 'fc'."
      ;;
    uninstall)
      for rc in "${rc_files[@]}"; do
        if ! grep -qF "$alias_line" "$rc" 2>/dev/null; then
          echo "fireclaude: alias not found in $rc — skipping."
          continue
        fi
        if [[ "$yes" -eq 0 ]]; then
          read -r -p "Remove fireclaude alias lines from $rc? [y/N] " _ans
          _ans="${_ans:-N}"
          [[ "$_ans" =~ ^[Yy]$ ]] || { echo "Skipped $rc."; continue; }
        fi
        # Remove the comment line and the alias line
        sed -i '/# fireclaude short alias (added by fireclaude alias install)/d' "$rc"
        sed -i "/alias fc='fireclaude'/d" "$rc"
        echo "fireclaude: removed alias from $rc"
      done
      ;;
    *) die "alias: unknown subcommand '$sub' (install|uninstall)" ;;
  esac
}

main() {
  local cmd="${1:-}"; [[ -n "$cmd" ]] || { usage; exit 1; }
  shift
  case "$cmd" in
    setup)          cmd_setup "$@" ;;
    start)          cmd_start "$@" ;;
    stop)           cmd_stop "$@" ;;
    teardown)       cmd_teardown "$@" ;;
    upgrade)        cmd_upgrade "$@" ;;
    version)        cmd_version "$@" ;;
    doctor)         cmd_doctor "$@" ;;
    ollama-start)   cmd_ollama_start "$@" ;;
    health)         cmd_health "$@" ;;
    status)         cmd_status "$@" ;;
    logs)           cmd_logs "$@" ;;
    scrape)         cmd_scrape "$@" ;;
    map)            cmd_map "$@" ;;
    search)         cmd_search "$@" ;;
    batch)          cmd_batch "$@" ;;
    crawl)          cmd_crawl "$@" ;;
    extract)        cmd_extract "$@" ;;
    model)          cmd_model "$@" ;;
    changes)        cmd_changes "$@" ;;
    webhook-listen) cmd_webhook_listen "$@" ;;
    alias)          cmd_alias "$@" ;;
    -h|--help|help) usage ;;
    *) usage; exit 1 ;;
  esac
}
main "$@"
